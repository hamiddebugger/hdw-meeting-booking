<?xml version="1.0"?>
<ruleset name="HDW Meeting Booking">
    <description>Coding standards for HDW Meeting Booking plugin.</description>

    <file>src/</file>
    <file>hdw-meeting-booking.php</file>

    <arg name="basepath" value="."/>
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Docs"/>

    <rule ref="WordPress.Files.FileName">
        <properties>
            <property name="strict_class_file_names" value="false"/>
        </properties>
    </rule>
</ruleset>
